{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cofrinhoreal.com.br/schemas/regiao.schema.json",
  "title": "Regiao brasileira",
  "type": "object",
  "required": ["id_ibge", "slug", "nome", "ufs"],
  "properties": {
    "id_ibge": {"type": "integer", "minimum": 1, "maximum": 5},
    "slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "nome": {"type": "string", "minLength": 1},
    "ufs": {"type": "array", "minItems": 3, "items": {"type": "string", "pattern": "^[A-Z]{2}$"}}
  },
  "additionalProperties": false
}
